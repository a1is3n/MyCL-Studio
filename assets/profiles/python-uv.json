{
  "stack_id": "python-uv",
  "commands": {
    "install": "uv sync",
    "dev": "uv run uvicorn main:app --reload",
    "build": null,
    "test": "uv run pytest",
    "lint": "uv run ruff check .",
    "lint_fix": "uv run ruff check . --fix",
    "lint_scoped": "uv run ruff check {files}",
    "lint_fix_scoped": "uv run ruff check {files} --fix",
    "simplify": null,
    "perf": null,
    "security": "uv run pip-audit",
    "integration": "uv run pytest tests/integration/"
  },
  "e2e_by_project_type": {
    "web": "uv run pytest --headed",
    "api": "hurl --test tests/e2e/*.hurl",
    "cli": null,
    "library": null,
    "ml": null,
    "default": "uv run pytest tests/e2e/"
  },
  "load_by_project_type": {
    "web": "k6 run loadtest.js",
    "api": "uv run locust -f loadtest.py --headless -u 100 -r 10 -t 1m",
    "default": null
  },
  "default_port": 8000,
  "manifest_files": ["pyproject.toml", "uv.lock"]
}
