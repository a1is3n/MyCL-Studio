{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MyCL Phase 4 — Engineering Spec",
  "type": "object",
  "required": ["title", "scope", "acceptance_criteria", "out_of_scope", "risks"],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 120,
      "description": "Short specific spec title (5-10 words)."
    },
    "scope": {
      "type": "string",
      "minLength": 50,
      "maxLength": 2000,
      "description": "1-2 paragraphs — what's included AND what's excluded."
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 3,
      "maxItems": 7,
      "description": "Testable conditions. Each AC independently verifiable.",
      "items": {
        "type": "object",
        "required": ["id", "statement"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AC[0-9]+$",
            "description": "Reference id, AC1..AC9 etc."
          },
          "statement": {
            "type": "string",
            "minLength": 10,
            "maxLength": 500,
            "description": "Given/when/then or clear binary check."
          }
        }
      }
    },
    "out_of_scope": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": { "type": "string", "minLength": 5, "maxLength": 300 }
    },
    "risks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["title", "detail"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string", "minLength": 3, "maxLength": 80 },
          "detail": { "type": "string", "minLength": 10, "maxLength": 400 }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "maxItems": 7,
      "description": "#1 visibility: assumptions the user did NOT explicitly state but the spec depends on. Optional (omit if none). Surfaced to the user, NOT a gate.",
      "items": {
        "type": "object",
        "required": ["assumption", "why"],
        "additionalProperties": false,
        "properties": {
          "assumption": { "type": "string", "minLength": 5, "maxLength": 300 },
          "why": { "type": "string", "minLength": 3, "maxLength": 300 }
        }
      }
    }
  }
}
